{
  "name": "pidgn-templates",
  "displayName": "Pidgn Templates",
  "description": "Syntax highlighting, snippets, and language support for Pidgn framework templates (.html.pidgn) — variables, conditionals, loops, partials, layouts, pipes, and i18n.",
  "version": "0.3.1",
  "publisher": "pidgn-framework",
  "icon": "icon.png",
  "license": "MIT",
  "author": {
    "name": "Ivan Stamenkovic"
  },
  "homepage": "https://pidgn.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/seemsindie/pidgn_vscode"
  },
  "bugs": {
    "url": "https://github.com/seemsindie/pidgn_vscode/issues"
  },
  "keywords": [
    "pidgn",
    "template",
    "handlebars",
    "mustache",
    "zig",
    "web framework",
    "i18n"
  ],
  "galleryBanner": {
    "color": "#F4BB44",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pidgn",
        "aliases": [
          "Pidgn Template",
          "pidgn"
        ],
        "extensions": [
          ".html.pidgn",
          ".pidgn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pidgn",
        "scopeName": "text.html.pidgn",
        "path": "./syntaxes/pidgn.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "source.js": "javascript",
          "source.css": "css"
        }
      }
    ],
    "snippets": [
      {
        "language": "pidgn",
        "path": "./snippets/pidgn.json"
      }
    ]
  }
}
